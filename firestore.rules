rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(docData) {
      return request.auth.uid == docData.citizenId;
    }

    function isAdmin() {
      return request.auth.token.role == 'admin' || request.auth.token.role == 'superAdmin';
    }

    // Collection: service_requests
    match /service_requests/{requestId} {
      allow read: if isAdmin() || (isAuth() && resource.data.citizenId == request.auth.uid);
      allow list: if isAdmin() || (isAuth() && request.query.where.citizenId == request.auth.uid);
      allow create: if isAuth() && request.resource.data.citizenId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Collection: incidents
    match /incidents/{incidentId} {
      allow read: if isAdmin() || (isAuth() && resource.data.citizenId == request.auth.uid);
      allow list: if isAdmin() || (isAuth() && request.query.where.citizenId == request.auth.uid);
      allow create: if isAuth(); // Anonymous reports have null citizenId, so ownership check is tricky
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
     // Collection: animals_for_adoption
    match /animals_for_adoption/{animalId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin() && (request.auth.token.department == 'bem_estar_animal' || request.auth.token.role == 'superAdmin');
    }
    
    // Collection: lost_found_posts
    match /lost_found_posts/{postId} {
        allow read: if true;
        allow create: if isAuth() && request.resource.data.citizenId == request.auth.uid;
        allow update: if isAuth() && resource.data.citizenId == request.auth.uid; // Only owner can update
        allow delete: if isAdmin();
    }

  }
}
