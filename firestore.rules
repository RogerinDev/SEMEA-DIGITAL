
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() {
      return request.auth != null;
    }
    function isSuperAdmin() {
      return isAuth() && request.auth.token.role == 'superAdmin';
    }
    function isAdmin() {
      return isAuth() && (request.auth.token.role == 'admin' || isSuperAdmin());
    }
    function isOwner(citizenId) {
      return isAuth() && request.auth.uid == citizenId;
    }

    match /users/{userId} {
      allow read, update: if isOwner(userId) || isAdmin();
      allow create, delete: if isAdmin();
    }

    match /service_requests/{requestId} {
      allow create: if isOwner(request.resource.data.citizenId);
      allow read: if isAdmin() || isOwner(resource.data.citizenId);
      allow update: if isAdmin();
      allow list: if isAdmin() || (isAuth() && request.query.where.citizenId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /incidents/{incidentId} {
      allow create: if isAuth();
      allow read: if isAdmin() || isOwner(resource.data.citizenId);
      allow update: if isAdmin();
      allow list: if isAdmin() || (isAuth() && request.query.where.citizenId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /lost_found_posts/{postId} {
      allow read, list: if true;
      allow create: if isOwner(request.resource.data.citizenId);
      allow update: if isAdmin() || isOwner(resource.data.citizenId);
      allow delete: if isAdmin();
    }

    match /animals_for_adoption/{animalId} {
      allow read, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /adoption_interests/{interestId} {
      allow create: if isOwner(request.resource.data.citizenId);
      allow read, list, update, delete: if isAdmin();
    }
    
    // Regra para Solicitações de Educação Ambiental (PÚBLICO)
    match /education_requests/{requestId} {
      // Qualquer pessoa (mesmo não logada) pode criar uma solicitação
      allow create: if true;
      // Apenas Admins podem ler ou atualizar
      allow read, update, delete: if isAdmin(); 
    }

    // Regra para Configurações de Setor
    match /sector_settings/urban_afforestation {
        // Permite que todos leiam, para exibir os dados nas páginas públicas.
        allow read: if true;
        // Permite escrita apenas para super admins ou admins do setor de arborização.
        allow write: if isAdmin() && (isSuperAdmin() || request.auth.token.department == 'arborizacao');
    }
  }
}
