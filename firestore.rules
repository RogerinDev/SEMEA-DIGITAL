
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Regras do Firestore podem ser adicionadas aqui no futuro.
    // Por enquanto, permite leitura e escrita se o usuário estiver autenticado.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    // Regra geral: Permite a leitura de todos os arquivos por qualquer pessoa.
    // Isso é útil para exibir imagens públicas no site (ex: fotos de animais).
    allow read;

    // Regra específica para uploads:
    // Permite que um usuário autenticado escreva (faça upload) em qualquer caminho.
    // A segurança é aprimorada ao restringir os caminhos de upload no código do cliente,
    // por exemplo, usando o UID do usuário no nome do arquivo/caminho para garantir
    // que eles só possam "sobrescrever" seus próprios uploads potenciais.
    allow write: if request.auth != null;
  }
}
