rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Regra geral de leitura: permite que qualquer pessoa leia arquivos.
    // Isso é comum para imagens que precisam ser exibidas publicamente no app.
    // Ajuste para `if request.auth != null;` se os arquivos forem privados.
    match /{allPaths=**} {
      allow read;
    }

    // --- REGRAS DE ESCRITA (UPLOAD) ---

    // Permite que usuários logados façam upload de fotos para seus perfis.
    match /profile_pictures/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Permite que usuários logados façam upload de evidências para denúncias.
    match /incident_evidence/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Permite que usuários logados façam upload de fotos de animais perdidos/achados.
    match /lost_found_images/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Permite que administradores logados façam upload de fotos de animais para adoção.
    // A verificação de 'admin'/'superAdmin' deve ser feita na Cloud Function ou na App.
    // Aqui, garantimos que apenas um usuário autenticado pode escrever.
    match /adoption_images/{userId}/{allPaths=**} {
        allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
